# Public, non-secret application settings only.
# Copy to `.env` for local overrides (gitignored). Production prefers systemd
# Environment= lines + LoadCredential files — do not put real secrets here.

# --- Gateway (authenticated app host) ---
GS_APP_HOST=127.0.0.1
GS_APP_PORT=8080
GS_PUBLIC_ORIGIN=https://play.example.com
GS_COOKIE_SECURE=1
GS_DATA_DIR=/var/lib/galactic-sovereign/accounts
GS_DIST_DIR=/opt/galactic-sovereign/current/dist
GS_COOP_INTERNAL_URL=ws://127.0.0.1:9090

# --- Persistent co-op host (loopback only in production) ---
GS_COOP_HOST=127.0.0.1
GS_COOP_PORT=9090
GS_COOP_DATA_DIR=/var/lib/galactic-sovereign/multiplayer
GS_COOP_MAX_PLAYERS=5
GS_COOP_AUTOSAVE_MS=60000
GS_COOP_COMMANDS_PER_SECOND=20
GS_COOP_COMMAND_BURST=40

# --- Dev-only optional shared password (unused when gateway identity is active) ---
# GS_COOP_PASSWORD=
# GS_COOP_SEED=
# GS_COOP_RESET=0

# --- Secrets: NEVER commit real values ---
# Prefer systemd LoadCredential under /etc/galactic-sovereign/credentials/:
#   gateway-secret
#   session-pepper
#   cloudflare-tunnel-token
#   restic-password
#   restic-repository
#   r2-access-key-id
#   r2-secret-access-key
#
# Local / CI alternatives (empty placeholders only):
# GS_GATEWAY_SECRET=
# GS_SESSION_PEPPER=
# GS_GATEWAY_SECRET_FILE=/path/to/gateway-secret
# GS_SESSION_PEPPER_FILE=/path/to/session-pepper
# CREDENTIALS_DIRECTORY=/path/to/credentials

# --- Electron / Sol commander (local workstation only) ---
# OPENAI_API_KEY=
