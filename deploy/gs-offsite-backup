#!/usr/bin/env bash
set -euo pipefail

mode="${1:-daily}"
case "$mode" in hourly|daily) ;; *) echo 'usage: gs-offsite-backup [hourly|daily]' >&2; exit 2 ;; esac

credentials=/etc/galactic-sovereign/credentials
repository_file="$credentials/restic-repository"
password_file="$credentials/restic-password"
access_key_file="$credentials/r2-access-key-id"
secret_key_file="$credentials/r2-secret-access-key"
for file in "$repository_file" "$password_file" "$access_key_file" "$secret_key_file"; do
  [[ -r "$file" ]] || { echo "missing credential: $file" >&2; exit 1; }
done

export RESTIC_REPOSITORY="$(<"$repository_file")"
export RESTIC_PASSWORD_FILE="$password_file"
export AWS_ACCESS_KEY_ID="$(<"$access_key_file")"
export AWS_SECRET_ACCESS_KEY="$(<"$secret_key_file")"
export RESTIC_CACHE_DIR=/var/lib/galactic-sovereign/backups/restic-cache
install -d -m 0700 "$RESTIC_CACHE_DIR"

/usr/local/libexec/galactic-sovereign/gs-backup "$mode"

if [[ "$mode" == hourly ]]; then
  restic backup /var/lib/galactic-sovereign/backups/hourly \
    --tag galactic-sovereign --tag hourly
  restic forget --prune --keep-hourly 48 --keep-daily 14 --tag galactic-sovereign --tag hourly
else
  restic backup /var/lib/galactic-sovereign/backups/daily /var/lib/galactic-sovereign/pre-migration \
    --tag galactic-sovereign --tag daily
  restic forget --prune --keep-daily 14 --keep-weekly 8 --keep-monthly 12 --tag galactic-sovereign --tag daily
fi
