[Unit]
Description=Encrypted Galactic Sovereign offsite backup
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=root
Group=root
ExecStart=/usr/local/libexec/galactic-sovereign/gs-offsite-backup daily
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadOnlyPaths=/var/lib/galactic-sovereign/accounts /var/lib/galactic-sovereign/multiplayer /var/lib/galactic-sovereign/pre-migration
ReadWritePaths=/var/lib/galactic-sovereign/backups
UMask=0077
