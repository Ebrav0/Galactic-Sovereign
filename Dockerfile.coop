# Co-op simulation host (persistent WebSocket). Keep separate from the static game build.
FROM node:22-bookworm-slim

WORKDIR /app

COPY package.json package-lock.json ./
RUN npm ci --omit=dev

COPY server ./server
COPY src ./src

ENV NODE_ENV=production
ENV GS_COOP_HOST=0.0.0.0
ENV GS_COOP_PORT=9090
ENV GS_COOP_DATA_DIR=/data

RUN mkdir -p /data
VOLUME ["/data"]

EXPOSE 9090

CMD ["node", "server/coop-host.mjs"]
