{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Galactic Sovereign save file — version 8",
  "description": "Construction drones: timed structure builds with drone swarm (Phase 6).",
  "type": "object",
  "required": ["saveVersion", "checksum", "savedAt", "state"],
  "properties": {
    "saveVersion": { "const": 8 },
    "checksum": { "type": "string", "pattern": "^[0-9a-f]{8}$" },
    "savedAt": { "type": "number" },
    "state": {
      "type": "object",
      "required": [
        "meta", "time", "credits", "paused", "stronghold", "activeGalaxyId", "homeGalaxyId",
        "galaxies", "wormholes", "flagship", "scouts", "playerShips", "pirates",
        "systemBattles", "battleStance", "solarii", "solariiUnlocked",
        "empireQueue", "research", "factions", "aiShips", "constructionJobs", "drones"
      ],
      "properties": {
        "empireQueue": { "type": "array" },
        "research": { "type": "object" },
        "factions": { "type": "object" },
        "aiShips": { "type": "array" },
        "constructionJobs": { "type": "array" },
        "drones": { "type": "array" }
      }
    }
  }
}
