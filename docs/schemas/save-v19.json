{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Galactic Sovereign save file — version 19",
  "description": "Cinematic stellar catalog with deterministic exotic overrides and phased wormhole presentation.",
  "type": "object",
  "required": ["saveVersion", "checksum", "savedAt", "state"],
  "properties": {
    "saveVersion": { "const": 19 },
    "checksum": { "type": "string", "pattern": "^[0-9a-f]{8}$" },
    "savedAt": { "type": "number" },
    "state": {
      "type": "object",
      "required": ["galaxies", "wormholes"],
      "properties": {
        "galaxies": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "graph": {
                "type": "object",
                "properties": {
                  "stars": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "stellarOverride": {
                          "type": ["string", "null"],
                          "enum": ["binary", "red_supergiant", "blue_supergiant", "pulsar", "quasar", null]
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
