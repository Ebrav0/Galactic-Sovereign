{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Galactic Sovereign save file — version 12",
  "description": "Unified physical logistics, tactical orders, battle reports, and optional Sol commander preferences.",
  "type": "object",
  "required": ["saveVersion", "checksum", "savedAt", "state"],
  "properties": {
    "saveVersion": { "const": 12 },
    "checksum": { "type": "string", "pattern": "^[0-9a-f]{8}$" },
    "savedAt": { "type": "number" },
    "state": {
      "type": "object",
      "required": [
        "meta", "time", "credits", "paused", "stronghold", "activeGalaxyId", "homeGalaxyId",
        "galaxies", "wormholes", "flagship", "scouts", "playerShips", "battleGroups", "pirates",
        "systemBattles", "battleStance", "solarii", "solariiUnlocked", "empireQueue", "research",
        "factions", "aiShips", "milestones", "campaign", "diplomacy", "superweapon",
        "heroFlagships", "manualTradeRoutes", "builderDrones", "logistics", "tacticalOrders",
        "battleReports", "solCommander"
      ],
      "properties": {
        "galaxies": { "type": "object" },
        "logistics": {
          "type": "object",
          "required": ["version", "nextConvoyId", "depots", "convoys", "routes", "stats"],
          "properties": {
            "version": { "const": 1 },
            "nextConvoyId": { "type": "number", "minimum": 1 },
            "depots": { "type": "object" },
            "convoys": { "type": "array" },
            "routes": { "type": "array" },
            "blockades": { "type": "object" },
            "stats": { "type": "object" },
            "lastDispatchAt": { "type": "number" }
          }
        },
        "tacticalOrders": { "type": "object" },
        "battleReports": { "type": "array" },
        "solCommander": {
          "type": "object",
          "required": ["version", "settings", "history"],
          "properties": {
            "version": { "const": 1 },
            "settings": {
              "type": "object",
              "required": ["enabled", "providerMode", "model", "confirmationRequired", "previewData", "requestLimitPerHour", "spendingCapUsd"],
              "properties": {
                "enabled": { "type": "boolean" },
                "providerMode": { "enum": ["offline", "sol"] },
                "model": { "type": "string" },
                "confirmationRequired": { "const": true },
                "previewData": { "type": "boolean" },
                "requestLimitPerHour": { "type": "number", "minimum": 1 },
                "spendingCapUsd": { "type": "number", "minimum": 0 }
              }
            },
            "history": { "type": "array" }
          }
        }
      }
    }
  }
}
