{
  "name": "galactic-sovereign",
  "version": "0.1.0",
  "description": "Lane-based galactic strategy game — Electron + HTML5 Canvas",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "electron": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "build:standalone": "vite build --config vite.standalone.config.js",
    "build": "npm run build:standalone && vite build && node scripts/write-sites-worker.mjs",
    "app": "node server/app-host.mjs",
    "admin:create": "node server/admin-cli.mjs create-owner",
    "verify:hosted-auth": "node scripts/verify-hosted-auth.mjs",
    "verify:hosted-ui": "node scripts/verify-hosted-ui.mjs",
    "verify:hosted-load": "node scripts/verify-hosted-load.mjs",
    "verify:world-migration": "node scripts/verify-world-migration.mjs",
    "verify:security": "node scripts/verify-security-hardening.mjs",
    "electron:prod": "npm run build && electron .",
    "coop": "node server/coop-host.mjs",
    "coop:smoke": "node scripts/coop-smoke.mjs",
    "coop:gate": "node scripts/coop-gate.mjs",
    "coop:ship": "node scripts/coop-ship-readiness.mjs",
    "coop:fps": "node scripts/coop-fps-probe.mjs",
    "coop:reset": "GS_COOP_RESET=1 node server/coop-host.mjs"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "playwright": "^1.61.1",
    "vite": "^8.1.3",
    "wait-on": "^9.0.10"
  },
  "dependencies": {
    "@node-rs/argon2": "^2.0.2",
    "ws": "^8.21.1"
  }
}
